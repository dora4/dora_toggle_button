<?xml version="1.0" encoding="utf-8"?>

<resources>
    <declare-styleable name="DoraToggleButton">
        <attr name="dora_shadow_radius" format="reference|dimension" />
        <attr name="dora_shadow_offset" format="reference|dimension" />
        <attr name="dora_shadow_color" format="reference|color" />
        <attr name="dora_uncheck_color" format="reference|color" />
        <attr name="dora_checked_color" format="reference|color" />

        <attr name="dora_border_width" format="reference|dimension" />
        <attr name="dora_checkline_color" format="reference|color" />
        <attr name="dora_checkline_width" format="reference|dimension" />
        <attr name="dora_uncheckcircle_color" format="reference|color" />
        <attr name="dora_uncheckcircle_width" format="reference|dimension" />
        <attr name="dora_uncheckcircle_radius" format="reference|dimension" />

        <attr name="dora_checked" format="reference|boolean" />
        <attr name="dora_shadow_effect" format="reference|boolean" />
        <attr name="dora_effect_duration" format="reference|integer" />
        <attr name="dora_button_color" format="reference|color" />
        <attr name="dora_show_indicator" format="reference|boolean" />
